{
  "name": "caixaagil-api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend da plataforma web do Caixa Agil.",
  "main": "src/server.js",
  "scripts": {
    "build": "sucrase ./src -d ./dist --transforms imports",
    "dev": "nodemon src/server.js",
    "start": "node dist/server.js",
    "sequelize": "sequelize",
    "migrate": "sequelize db:migrate",
    "migrate:undo": "sequelize db:migrate:undo",
    "migrate:undo:all": "sequelize db:migrate:undo:all",
    "seed": "sequelize db:seed:all",
    "seed:undo": "sequelize db:seed:undo",
    "seed:undo:all": "sequelize db:seed:undo:all",
    "check:env:production": "node scripts/ops/check-required-env.js production",
    "legacy:export:caixa-agil": "node scripts/migration/export-legacy-caixa-agil.js",
    "legacy:import:caixa-agil": "node scripts/migration/import-legacy-caixa-agil.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-forge": "^1.4.0",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "sequelize-cli": "^6.6.3",
    "sucrase": "^3.35.1"
  }
}
