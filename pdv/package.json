{
  "name": "caixaagil-pdv",
  "version": "0.24.0",
  "private": true,
  "description": "App desktop do Caixa Agil para operacao de caixa e ativacao de PDV.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "next dev --webpack -p 3030",
    "dev:electron": "wait-on http://localhost:3030 && electron electron/main.cjs",
    "build:fiscal-worker": "dotnet build fiscal-worker/CaixaAgil.FiscalWorker/CaixaAgil.FiscalWorker.csproj",
    "publish:fiscal-worker": "dotnet publish fiscal-worker/CaixaAgil.FiscalWorker/CaixaAgil.FiscalWorker.csproj -c Release -r win-x64 --self-contained true -p:PublishSingleFile=true -p:PublishTrimmed=false -p:EnableCompressionInSingleFile=false -p:DebugType=None -p:DebugSymbols=false -p:PublishReadyToRun=false -o electron/resources/fiscal-worker/win-x64",
    "build": "next build",
    "dist": "npm run build && npm run publish:fiscal-worker && node scripts/build-electron.mjs --publish never",
    "dist:dir": "npm run build && npm run publish:fiscal-worker && node scripts/build-electron.mjs --dir",
    "release": "npm run dist",
    "start": "electron electron/main.cjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.8.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sql.js": "^1.14.1",
    "typescript": "^5",
    "wait-on": "^9.0.3"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "build": {
    "appId": "br.com.caixaagil.pdv",
    "productName": "Caixa Agil PDV",
    "asar": true,
    "afterPack": "scripts/after-pack.mjs",
    "compression": "maximum",
    "electronLanguages": [
      "pt-BR",
      "en-US"
    ],
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!electron/resources/**",
      "out/**/*",
      "package.json",
      "!**/*.map",
      "!**/*.pdb",
      "!**/*.log",
      "!.next/**",
      "!src/**",
      "!fiscal-worker/**",
      "!docs/**"
    ],
    "extraResources": [
      {
        "from": "electron/resources/fiscal-worker/win-x64/CaixaAgil.FiscalWorker.exe",
        "to": "fiscal-worker/CaixaAgil.FiscalWorker.exe"
      },
      {
        "from": "electron/services/non-fiscal-receipt-printer.ps1",
        "to": "non-fiscal-receipt-printer.ps1"
      },
      {
        "from": "electron/services/rustdesk-support-installer.ps1",
        "to": "rustdesk-support-installer.ps1"
      },
      {
        "from": "node_modules/sql.js/dist",
        "to": "sqljs",
        "filter": [
          "sql-wasm.js",
          "sql-wasm.wasm"
        ]
      }
    ],
    "win": {
      "icon": "electron/assets/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "shortcutName": "Caixa Agil PDV"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Caf3z1n",
        "repo": "caixaagil-monorepo",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
